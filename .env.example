# =============================================================
# Lions Club of Baroda Rising Star — Environment Variables
# Copy to .env.local for local dev, set in Vercel for production.
# =============================================================

# --- Site -----------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://barodarisingstar.com
NEXT_PUBLIC_SITE_NAME="Lions Club of Baroda Rising Star"

# --- Supabase --------------------------------------------------
# Project: BarodaRisingStar (org: LCBRISING)
NEXT_PUBLIC_SUPABASE_URL=https://mvtqqlfzawyhntnsavbx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_PROJECT_ID=mvtqqlfzawyhntnsavbx

# --- Razorpay -------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# --- Resend (email) -------------------------------------------
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="Lions Club Baroda Rising Star <noreply@barodarisingstar.com>"

# --- Twilio (WhatsApp) ----------------------------------------
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Cron / Automation ----------------------------------------
CRON_SECRET=replace-with-long-random-string

# --- Admin bootstrap ------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=admin@barodarisingstar.com

# --- AI (OpenAI) ----------------------------------------------
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# --- Canva Connect API ----------------------------------------
# Generate from: https://www.canva.com/developers/integrations/connect-api
CANVA_CLIENT_ID=xxx
CANVA_CLIENT_SECRET=xxx
CANVA_API_KEY=xxx                # optional static token (skips the OAuth connect flow)
CANVA_REDIRECT_URI=https://YOUR_DOMAIN/api/canva/oauth/callback
# Connect an account (recommended) at /admin/integrations/canva — tokens are
# stored + auto-refreshed in the DB, so CANVA_CLIENT_ID/SECRET are enough.
# Brand template IDs (DAFxxxx) — publish templates in Canva, then map here.
CANVA_TEMPLATE_FLYER=
CANVA_TEMPLATE_INVITATION=
CANVA_TEMPLATE_BIRTHDAY=
CANVA_TEMPLATE_CERTIFICATE=
CANVA_TEMPLATE_POST=
CANVA_TEMPLATE_PRESS=

# --- Meta (Facebook + Instagram) ------------------------------
META_APP_ID=xxx
META_APP_SECRET=xxx
META_ACCESS_TOKEN=EAAxxx
FACEBOOK_PAGE_ID=xxx
INSTAGRAM_BUSINESS_ID=xxx

# --- LinkedIn -------------------------------------------------
LINKEDIN_CLIENT_ID=xxx
LINKEDIN_CLIENT_SECRET=xxx
LINKEDIN_ACCESS_TOKEN=xxx
LINKEDIN_ORGANIZATION_URN=urn:li:organization:000000

# --- WhatsApp Business (optional, alternative to Twilio) ------
WHATSAPP_BUSINESS_PHONE_ID=xxx
WHATSAPP_BUSINESS_TOKEN=EAAxxx

# --- Cloudinary (video + image rendering) ---------------------
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx
CLOUDINARY_UPLOAD_PRESET=lcbrs_default

# --- Branding -------------------------------------------------
NEXT_PUBLIC_BRAND_PRIMARY=#1e3a8a
NEXT_PUBLIC_BRAND_ACCENT=#fbbf24
NEXT_PUBLIC_BRAND_LOGO_URL=https://YOUR_DOMAIN/logo.png

# --- UPI / PhonePe collection ---------------------------------
# Server-side merchant VPA used to render QR + UPI deep links on
# the public /pay/[id] page. Defaults to the values below if unset.
UPI_VPA=9712299333@ybl
UPI_PAYEE_NAME="Lions Club of Baroda Rising Star"
UPI_MERCHANT_CODE=
# Public mirrors (exposed to the browser, never include secrets):
NEXT_PUBLIC_UPI_VPA=9712299333@ybl
NEXT_PUBLIC_UPI_PAYEE_NAME="Lions Club of Baroda Rising Star"
# PhonePe Business webhook (optional; enables auto-verification)
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=
# Optional static PhonePe QR barcode image (PNG/JPG) shown on the
# payment page when dynamic UPI VPA is not configured.
NEXT_PUBLIC_STATIC_QR_URL=
# Portal HMAC cookie signing (falls back to SUPABASE_SERVICE_ROLE_KEY).
PORTAL_SESSION_SECRET=

# --- Lions OIDC / SSO (Phase 1) --------------------------------
# Provider-agnostic OIDC client. Fill these in once you have credentials
# from LCI's Member Service Center (or your IdP: Auth0/Keycloak/Okta/...).
# Without these set, /api/auth/oidc/* returns 503.
LIONS_OIDC_ISSUER=https://login.example.com/realms/lions
LIONS_OIDC_DISCOVERY_URL=
LIONS_OIDC_CLIENT_ID=lcr-crm
LIONS_OIDC_CLIENT_SECRET=
LIONS_OIDC_REDIRECT_URI=https://YOUR_DOMAIN/api/auth/oidc/callback
LIONS_OIDC_SCOPES=openid profile email
LIONS_OIDC_AUDIENCE=
LIONS_OIDC_PROVIDER_LABEL=Lions

# --- Lions inbound webhook ------------------------------------
# Shared HMAC secret. The Lions provider must sign every payload with
# this key (HMAC-SHA256 hex) in the X-Lions-Signature header.
# Falls back to lions_api_settings.webhook_secret when unset.
LIONS_WEBHOOK_SECRET=

# --- Lions Portal (District Governor login) district sync -----
# Auto-syncs district data using a DG's Lions Member Portal login.
# Prefer configuring these encrypted via /admin/integrations/oidc
# (they override these env vars). NEVER commit real credentials.
# The login endpoint trades username/password for a session token;
# the data endpoint returns district records once authenticated.
LIONS_PORTAL_LOGIN_URL=
LIONS_PORTAL_DATA_URL=
LIONS_PORTAL_USERNAME=
LIONS_PORTAL_PASSWORD=
LIONS_PORTAL_DISTRICT_CODE=

# --- Lions sandbox sign-in gate -------------------------------
# The sandbox sign-in (/api/auth/oidc/sandbox) mints a privileged
# synthetic session for testing. It is enabled off live production
# (local dev + Vercel preview/branch deploys) automatically. Set this
# to "true" ONLY if you deliberately want it on the LIVE production
# domain. Leave blank/unset otherwise.
LIONS_SANDBOX_ALLOW_PRODUCTION=

# --- Secret encryption at rest --------------------------------
# 32-byte key (base64 or hex) used to AES-256-GCM wrap OAuth tokens,
# OIDC client_secret, and Lions API credentials before persisting.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating: keep the old key around to decrypt legacy rows, then re-save.
SECRET_ENCRYPTION_KEY=
